# マニング公式の定義
manning_v <- function(n, R, S) {
(1 / n) * (R^(2/3)) * (S^(1/2))
}
# テストデータの準備
baseline_params <- list(n = 0.015, R = 0.5, S = 0.01) # 前回（滑らかなコンクリート）
target_params   <- list(n = 0.025, R = 0.6, S = 0.015) # 今回（ザラザラで急勾配）
decompose_proto <- function(func, baseline, target) {
# 1. 起点（Base）と終点（Target）の数値を計算
v_base   <- do.call(func, baseline)
v_target <- do.call(func, target)
total_diff <- v_target - v_base
# 2. 各パラメータの「単独要因（Main Effect）」を計算
factors <- names(baseline)
main_effects <- numeric(length(factors))
names(main_effects) <- factors
for (f in factors) {
# ベースラインをコピーし、変数 f だけをターゲットの値に差し替える
p_temp <- baseline
p_temp[[f]] <- target[[f]]
# 「fだけを変えたときの値」から「ベースラインの値」を引く
main_effects[f] <- do.call(func, p_temp) - v_base
}
# 3. 複合要因（Interaction）は、全体の差分から単独要因の合計を引いた「残り」
interaction_effect <- total_diff - sum(main_effects)
# 4. 結果をデータフレームにまとめる
result <- data.frame(
Factor       = c(factors, "Interaction", "Total_Calculated", "Total_Actual"),
Contribution = c(main_effects, interaction_effect, sum(main_effects) + interaction_effect, total_diff)
)
return(result)
}
# 実行
decompose_proto(manning_v, baseline_params, target_params)
# 実行
decompose_proto_v2(manning_v, baseline_params, target_params)
decompose_proto_v2 <- function(func, baseline, target) {
# 1. 起点（Base）と終点（Target）の数値を計算
v_base   <- do.call(func, baseline)
v_target <- do.call(func, target)
total_diff <- v_target - v_base
factors <- names(baseline)
# --- 【アップデート】生の値と差分を入れる箱をそれぞれ用意 ---
simulated_values <- numeric(length(factors))
names(simulated_values) <- factors
main_effects <- numeric(length(factors))
names(main_effects) <- factors
# 2. ループ処理
for (f in factors) {
p_temp <- baseline
p_temp[[f]] <- target[[f]]
# 【変更点】まずは関数の実行結果（生の値）をそのまま保存！
v_sim <- do.call(func, p_temp)
simulated_values[f] <- v_sim
# 差分は、生の値からベースラインの値を引いて計算
main_effects[f] <- v_sim - v_base
}
# 3. 複合要因の計算
interaction_effect <- total_diff - sum(main_effects)
# 4. 結果をデータフレームにまとめる（「生の値」の列を追加）
# ※ Interaction は単一の生の値が存在しないため、便宜上 NA にします
result <- data.frame(
Factor          = c("Baseline", factors, "Interaction", "Target"),
Value_Simulated = c(v_base, simulated_values, NA, v_target),
Contribution    = c(0, main_effects, interaction_effect, total_diff)
)
return(result)
}
# 実行
decompose_proto_v2(manning_v, baseline_params, target_params)
decompose_v3 <- function(func, baseline, target, method = c("interaction", "shapley")) {
method <- match.arg(method)
factors <- names(baseline)
n_vars <- length(factors)
# 1. 起点（Base）と終点（Target）の数値を計算
v_base   <- do.call(func, baseline)
v_target <- do.call(func, target)
total_diff <- v_target - v_base
# --- パターンA：Interaction モード（これまでのロジック） ---
if (method == "interaction") {
simulated_values <- numeric(n_vars)
names(simulated_values) <- factors
main_effects <- numeric(n_vars)
names(main_effects) <- factors
for (f in factors) {
p_temp <- baseline
p_temp[[f]] <- target[[f]]
v_sim <- do.call(func, p_temp)
simulated_values[f] <- v_sim
main_effects[f] <- v_sim - v_base
}
interaction_effect <- total_diff - sum(main_effects)
result <- data.frame(
Factor          = c("Baseline", factors, "Interaction", "Target"),
Value_Simulated = c(v_base, simulated_values, NA, v_target),
Contribution    = c(0, main_effects, interaction_effect, total_diff)
)
return(result)
}
# --- パターンB：Shapley モード（新規実装の厳密按分） ---
if (method == "shapley") {
# ① 2^n パターンの引数の組み合わせ（ON/OFFのフラグ）を生成
# 0 = Baselineの値を使う, 1 = Targetの値を使う
grid <- expand.grid(replicate(n_vars, c(0, 1), simplify = FALSE))
colnames(grid) <- factors
# ② すべての組み合わせにおける関数の出力値を事前に一回ずつ計算（キャッシュ化）
cache_values <- numeric(nrow(grid))
for (i in 1:nrow(grid)) {
p_temp <- baseline
for (f in factors) {
if (grid[i, f] == 1) p_temp[[f]] <- target[[f]]
}
cache_values[i] <- do.call(func, p_temp)
}
# 各因子の貢献度を入れる箱
shapley_effects <- numeric(n_vars)
names(shapley_effects) <- factors
# ③ シャプレー値の数理計算（重み付け和）
for (f in factors) {
effect_sum <- 0
# 因子 f が「OFF(0)」であるすべての行（サブセット S）をループ
off_rows <- which(grid[[f]] == 0)
for (r_off in off_rows) {
# 該当する行で、他にON(1)になっている変数の数（|S|）を数える
s_size <- sum(grid[r_off, , drop = FALSE])
# 因子 f を「ON(1)」に変えたペアの行を探す
match_criteria <- grid[r_off, , drop = FALSE]
match_criteria[[f]] <- 1
r_on <- which(apply(grid, 1, function(row) identical(as.numeric(row), as.numeric(match_criteria))))
# 限界寄与（ONのときの値 - OFFのときの値）
marginal_contribution <- cache_values[r_on] - cache_values[r_off]
# シャプレーの重み公式: |S|! * (n - |S| - 1)! / n!
weight <- (factorial(s_size) * factorial(n_vars - s_size - 1)) / factorial(n_vars)
effect_sum <- effect_sum + (marginal_contribution * weight)
}
shapley_effects[f] <- effect_sum
}
# 結果をデータフレームにまとめる
# ※ Shapleyモードではすべての効果が各因子に按分されるため、
#    単一の「Value_Simulated」は定義できずNAになります（BaselineとTargetを除く）
result <- data.frame(
Factor          = c("Baseline", factors, "Target"),
Value_Simulated = c(v_base, rep(NA, n_vars), v_target),
Contribution    = c(0, shapley_effects, total_diff)
)
return(result)
}
}
manning_v <- function(n, R, S) { (1 / n) * (R^(2/3)) * (S^(1/2)) }
baseline_params <- list(n = 0.015, R = 0.5, S = 0.01)
target_params   <- list(n = 0.025, R = 0.6, S = 0.015)
# ① これまでのInteractionモード
decompose_v3(manning_v, baseline_params, target_params, method = "interaction")
# ② 新しいShapleyモード（厳密按分）
decompose_v3(manning_v, baseline_params, target_params, method = "shapley")
decompose_v4 <- function(func, baseline, target, allocate = FALSE) {
factors <- names(baseline)
n_vars <- length(factors)
# 1. 起点（Base）と終点（Target）の数値を計算
v_base   <- do.call(func, baseline)
v_target <- do.call(func, target)
total_diff <- v_target - v_base
# --- パターンA：allocate = FALSE（複合要因をそのまま出す） ---
if (!allocate) {
simulated_values <- numeric(n_vars)
names(simulated_values) <- factors
main_effects <- numeric(n_vars)
names(main_effects) <- factors
for (f in factors) {
p_temp <- baseline
p_temp[[f]] <- target[[f]]
v_sim <- do.call(func, p_temp)
simulated_values[f] <- v_sim
main_effects[f] <- v_sim - v_base
}
interaction_effect <- total_diff - sum(main_effects)
result <- data.frame(
Factor          = c("Baseline", factors, "Interaction", "Target"),
Value_Simulated = c(v_base, simulated_values, NA, v_target),
Contribution    = c(0, main_effects, interaction_effect, total_diff)
)
return(result)
}
# --- パターンB：allocate = TRUE（シャプレー値を用いて完璧に按分する） ---
if (allocate) {
# 2^n パターンの引数の組み合わせ（ON/OFFのフラグ）を生成
grid <- expand.grid(replicate(n_vars, c(0, 1), simplify = FALSE))
colnames(grid) <- factors
# すべての組み合わせにおける関数の出力値を事前に計算（キャッシュ化）
cache_values <- numeric(nrow(grid))
for (i in 1:nrow(grid)) {
p_temp <- baseline
for (f in factors) {
if (grid[i, f] == 1) p_temp[[f]] <- target[[f]]
}
cache_values[i] <- do.call(func, p_temp)
}
shapley_effects <- numeric(n_vars)
names(shapley_effects) <- factors
# シャプレー値の数理計算（重み付け和）
for (f in factors) {
effect_sum <- 0
off_rows <- which(grid[[f]] == 0)
for (r_off in off_rows) {
s_size <- sum(grid[r_off, , drop = FALSE])
match_criteria <- grid[r_off, , drop = FALSE]
match_criteria[[f]] <- 1
r_on <- which(apply(grid, 1, function(row) identical(as.numeric(row), as.numeric(match_criteria))))
marginal_contribution <- cache_values[r_on] - cache_values[r_off]
weight <- (factorial(s_size) * factorial(n_vars - s_size - 1)) / factorial(n_vars)
effect_sum <- effect_sum + (marginal_contribution * weight)
}
shapley_effects[f] <- effect_sum
}
result <- data.frame(
Factor          = c("Baseline", factors, "Target"),
Value_Simulated = c(v_base, rep(NA, n_vars), v_target),
Contribution    = c(0, shapley_effects, total_diff)
)
return(result)
}
}
# 通常モード（計算のズレをそのまま残して厳密にチェックしたいとき）
decompose_v4(manning_v, baseline_params, target_params, allocate = FALSE)
manning_v <- function(n, R, S) { (1 / n) * (R^(2/3)) * (S^(1/2)) }
baseline_params <- list(n = 0.015, R = 0.5, S = 0.01)
target_params   <- list(n = 0.025, R = 0.6, S = 0.015)
# 通常モード（計算のズレをそのまま残して厳密にチェックしたいとき）
decompose_v4(manning_v, baseline_params, target_params, allocate = FALSE)
# 按分モード（報告用に、複合要因を各ファクターに綺麗に分配しきりたいとき）
decompose_v4(manning_v, baseline_params, target_params, allocate = TRUE)
