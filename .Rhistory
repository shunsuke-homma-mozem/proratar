devtools::load_all(".")
w <- c(100, 4, 3)
prorate_int(total = 10, weights = w, adjust = "each")
prorate_int(total = 10, weights = w, adjust = "max")
prorate_int(total = -100, weights = c(1, 2, -0.5), adjust = "each")
prorate(total = 100, weights = c(1, 2), digits = 1.5, adjust = "max")
prorate_int(total = 100.5, weights = c(1, 2))
prorate_int(total = 100, weights = c(10, -10))
prorate(total = 1000, weights = w, digits = 1, adjust = "max")
prorate(total = 1000, weights = w, digits = - 1, adjust = "max")
prorate(total = 1003, weights = w, digits = - 1, adjust = "max")
prorate(total = 1003, weights = w, digits = 0, adjust = "max")
prorate(total = 1003, weights = w, digits = 0, adjust = "each")
library(dplyr)
# テスト用データフレーム（Autoは5000、Fireは1500を配賦したい）
test_df <- data.frame(
line          = c("Auto", "Auto", "Auto", "Fire", "Fire"),
weight        = c(10, 20, 20, 1, 2),
total_reserve = c(5000, 5000, 5000, 1500, 1500)
)
# 実行（total_reserveをそのまま渡してもエラーにならず、グループごとに整数按分される）
result <- test_df |>
group_by(line) |>
mutate(allocated = prorate_int(total = total_reserve, weights = weight, adjust = "each")) |>
ungroup()
