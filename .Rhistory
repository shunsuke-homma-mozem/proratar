line          = c("Auto", "Auto", "Auto", "Fire", "Fire"),
weight        = c(10, 20, 20, 1, 2),
total_reserve = c(5000, 5000, 5000, 1500, 1500)
)
# 実行（total_reserveをそのまま渡してもエラーにならず、グループごとに整数按分される）
